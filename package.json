{
  "name": "partnerforge-web",
  "private": true,
  "version": "0.1.0",
  "description": "PartnerForge web frontends — console + portal. Calls the partner-forge REST API at /v1/*; baked into the API's Fly deploy at build time.",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/api-types/deps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "sync-api-types": "./packages/api-types/scripts/sync.sh"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
